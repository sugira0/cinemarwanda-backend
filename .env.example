PORT=5000
MONGO_URI=mongodb://localhost:27017/rwandan_movies
# Optional: override Node's DNS resolvers when using mongodb+srv URLs on networks
# whose default DNS refuses SRV lookups.
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET=replace_this_with_a_long_random_secret
CLIENT_URL=https://your-frontend-domain.com
# Temporary admin recovery token used by POST /api/auth/admin/setup.
# Set this in production only when you need to create/reset the admin account.
ADMIN_SETUP_TOKEN=

# Firebase Admin SDK for verifying Firebase Auth ID tokens.
# Use values from a Firebase service account JSON. Keep these server-side only.
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Media storage
# Set MEDIA_BACKEND=cloudinary to store uploaded posters, actor photos, and videos
# in shared cloud storage instead of the local server/uploads folder.
MEDIA_BACKEND=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=cinema-rwanda
# Chunk size for large video uploads in bytes. Cloudinary defaults to 20 MB;
# 6 MB is a good lower-memory starting point for app servers.
CLOUDINARY_VIDEO_CHUNK_SIZE=6000000

# SMTP email delivery
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=replace_with_your_smtp_password
EMAIL_FROM="CINEMA Rwanda <noreply@yourdomain.com>"

# EmailJS template delivery for OTP emails
# Your template can use values like:
# {{to_email}}, {{to_name}}, {{otp_code}}, {{message}}, {{title}}, {{subject}}, {{expires_in_minutes}}
EMAILJS_SERVICE_ID=service_msfnda3
EMAILJS_TEMPLATE_ID=template_nw5134u
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
# Optional: set to true only if you explicitly want local console-preview emails
# in non-production environments when EmailJS/SMTP delivery fails.
ALLOW_DEV_EMAIL_PREVIEW=false

# WhatsApp verification delivery
# Option 1: Meta Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v22.0

# Option 2: Generic WhatsApp gateway endpoint
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
